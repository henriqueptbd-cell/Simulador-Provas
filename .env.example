# Copie este arquivo como .env e preencha os valores
PORT=3000
NODE_ENV=development

# ---------------------------------------------------
# SMTP — necessário para enviar e-mails de relatos
# Deixe em branco para salvar relatos apenas localmente
# ---------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# E-mail que receberá os relatos (padrão: henriqueptbd@gmail.com)
REPORT_TO=henriqueptbd@gmail.com
